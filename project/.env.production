# Production Environment Template
# Copy this and fill in real values when deploying to production

# GitHub Personal Access Token
GITHUB_TOKEN=ghp_your_token_here

# Groq API Key (MUST start with gsk_)
GROQ_API_KEY=gsk_your_key_here

# Server Port (Cloud platforms auto-assign this)
# Leave empty or set to 3000 for local, cloud will override
PORT=

# Daily refresh time (HH:mm, 24-hour format)
DAILY_REFRESH_TIME=00:00

# Optional: Node environment
NODE_ENV=production
